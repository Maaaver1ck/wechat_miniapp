<view class="page">
  <view class="campus-hero">
    <view class="hero-title">平台审核台</view>
    <view class="hero-subtitle">审核学生成为学校现有社团管理员的申请。</view>
  </view>

  <view class="section-title">待审核</view>
  <view wx:if="{{loading}}" class="card status-card">
    <view class="status-title">正在加载审核列表</view>
    <view class="status-copy">稍等一下，我们正在同步最新申请。</view>
  </view>
  <view wx:elif="{{loadFailed}}" class="card status-card">
    <view class="status-title">审核列表加载失败</view>
    <view class="status-copy">请检查平台审核相关云函数是否已部署完成。</view>
  </view>
  <view wx:elif="{{pending.length === 0}}" class="empty">目前没有待审核申请。</view>
  <view wx:for="{{pending}}" wx:key="id" class="card review-card">
    <view class="row space-between">
      <view class="club-name">{{item.clubName}}</view>
      <view class="tag warn">待审核</view>
    </view>
    <view class="student">{{item.applicantProfile.name}} · {{item.applicantProfile.studentId}}</view>
    <view class="muted">{{item.applicantProfile.college}} · {{item.applicantProfile.major}}</view>
    <view class="reason">{{item.reason}}</view>
    <view class="button-row">
      <button class="secondary-btn small-btn" data-id="{{item.id}}" data-status="rejected" bindtap="review" disabled="{{reviewingId}}">
        {{reviewingId === item.id ? '处理中...' : '拒绝'}}
      </button>
      <button class="primary-btn small-btn" data-id="{{item.id}}" data-status="approved" bindtap="review" disabled="{{reviewingId}}">
        {{reviewingId === item.id ? '处理中...' : '通过'}}
      </button>
    </view>
  </view>

  <view class="section-title">已处理</view>
  <view wx:if="{{!loading && !loadFailed && handled.length === 0}}" class="empty">还没有已处理申请。</view>
  <view wx:for="{{handled}}" wx:key="id" class="card review-card">
    <view class="row space-between">
      <view class="club-name">{{item.clubName}}</view>
      <view class="tag {{item.status === 'approved' ? '' : 'gray'}}">{{item.statusText}}</view>
    </view>
    <view class="student">{{item.applicantProfile.name}} · {{item.applicantProfile.studentId}}</view>
    <view class="muted">处理时间：{{item.reviewedAt}}</view>
  </view>
</view>
