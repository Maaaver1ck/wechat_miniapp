<view class="page">
  <view class="campus-hero">
    <view class="hero-title">{{isEdit ? '编辑活动' : '发布活动'}}</view>
    <view class="hero-subtitle">填写清晰的时间、地点和人数上限，方便同学报名。</view>
  </view>

  <view wx:if="{{loading}}" class="card status-card">
    <view class="status-title">正在准备活动表单</view>
    <view class="status-copy">我们正在读取可管理社团和活动信息。</view>
  </view>
  <view wx:elif="{{loadFailed}}" class="card status-card">
    <view class="status-title">活动表单加载失败</view>
    <view class="status-copy">请确认社团管理相关云函数已经部署完成。</view>
  </view>
  <form wx:else class="form-card activity-form" bindsubmit="submitActivity">
    <view class="field">
      <text class="label">所属社团</text>
      <picker mode="selector" range="{{clubs}}" range-key="name" value="{{clubIndex}}" bindchange="onClubChange">
        <view class="picker-value">{{selectedClubName}}</view>
      </picker>
    </view>
    <view class="field">
      <text class="label">活动名称</text>
      <input name="title" value="{{activity.title}}" placeholder="请输入活动名称" />
    </view>
    <view class="field">
      <text class="label">活动分类</text>
      <picker mode="selector" range="{{categories}}" value="{{categoryIndex}}" bindchange="onCategoryChange">
        <view class="picker-value">{{selectedCategory}}</view>
      </picker>
    </view>
    <view class="field">
      <text class="label">开始时间</text>
      <view class="picker-row">
        <picker mode="date" fields="day" value="{{startDate}}" bindchange="onStartDateChange">
          <view class="picker-value time-picker-value">{{startDate}}</view>
        </picker>
        <picker mode="time" value="{{startClock}}" bindchange="onStartClockChange">
          <view class="picker-value time-picker-value">{{startClock}}</view>
        </picker>
      </view>
    </view>
    <view class="field">
      <text class="label">活动时长</text>
      <picker mode="multiSelector" range="{{durationColumns}}" value="{{durationValue}}" bindchange="onDurationChange">
        <view class="picker-value">{{durationText}}</view>
      </picker>
    </view>
    <view class="field">
      <text class="label">报名截止</text>
      <view class="picker-row">
        <picker mode="date" fields="day" value="{{deadlineDate}}" bindchange="onDeadlineDateChange">
          <view class="picker-value time-picker-value">{{deadlineDate}}</view>
        </picker>
        <picker mode="time" value="{{deadlineClock}}" bindchange="onDeadlineClockChange">
          <view class="picker-value time-picker-value">{{deadlineClock}}</view>
        </picker>
      </view>
    </view>
    <view class="field">
      <text class="label">地点</text>
      <input name="location" value="{{activity.location}}" placeholder="请输入活动地点" />
    </view>
    <view class="field">
      <text class="label">报名方法</text>
      <picker mode="selector" range="{{registrationMethods}}" range-key="label" value="{{registrationMethodIndex}}" bindchange="onRegistrationMethodChange">
        <view class="picker-value">{{selectedRegistrationMethodLabel}}</view>
      </picker>
    </view>
    <view class="field">
      <text class="label">人数上限</text>
      <input wx:if="{{selectedRegistrationMethod === 'miniapp'}}" name="quota" value="{{activity.quota}}" type="number" placeholder="请输入人数上限" />
      <view wx:else class="muted disabled-value">当前报名方法无需填写人数上限</view>
    </view>
    <view wx:if="{{selectedRegistrationMethod === 'other'}}" class="field">
      <text class="label">报名方法说明</text>
      <textarea name="registrationNote" value="{{activity.registrationNote}}" placeholder="例如：请扫描海报二维码报名，或联系社团负责人" />
    </view>
    <view class="field">
      <text class="label">活动介绍</text>
      <textarea name="description" value="{{activity.description}}" placeholder="说明活动内容、适合人群和注意事项" />
    </view>
    <button class="primary-btn save-btn" form-type="submit" disabled="{{submitting || clubs.length === 0}}">
      {{submitting ? '保存中...' : '保存活动'}}
    </button>
  </form>
</view>
