.activity-form {
  margin-top: 28rpx;
}

.picker-value {
  min-height: 72rpx;
  display: flex;
  align-items: center;
  font-weight: 600;
}

.picker-row {
  display: flex;
  gap: 18rpx;
}

.picker-row picker {
  flex: 1;
  min-width: 0;
}

.time-picker-value {
  box-sizing: border-box;
  padding: 0 18rpx;
  border-radius: 18rpx;
  background: #f6f8ff;
}

.save-btn {
  margin-top: 28rpx;
}
