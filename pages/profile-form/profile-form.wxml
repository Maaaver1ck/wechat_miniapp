<view class="page">
  <view class="campus-hero">
    <view class="hero-title">完善学生资料</view>
    <view class="hero-subtitle">首次填写后，报名活动会自动带出这些信息。</view>
  </view>

  <view wx:if="{{loading}}" class="card status-card">
    <view class="status-title">正在读取资料</view>
    <view class="status-copy">如果你之前填写过资料，这里会自动带出。</view>
  </view>

  <form wx:else class="form-card profile-form" bindsubmit="submitProfile">
    <view class="field">
      <text class="label">姓名</text>
      <input name="name" value="{{profile.name}}" placeholder="请输入真实姓名" />
    </view>
    <view class="field">
      <text class="label">学号</text>
      <input name="studentId" value="{{profile.studentId}}" placeholder="请输入学号" />
    </view>
    <view class="field">
      <text class="label">学院</text>
      <input name="college" value="{{profile.college}}" placeholder="例如：信息工程学院" />
    </view>
    <view class="field">
      <text class="label">专业</text>
      <input name="major" value="{{profile.major}}" placeholder="例如：软件工程" />
    </view>
    <view class="field">
      <text class="label">手机号</text>
      <input name="phone" value="{{profile.phone}}" type="number" placeholder="请输入手机号" />
    </view>
    <button class="primary-btn save-btn" form-type="submit" disabled="{{submitting}}">
      {{submitting ? '保存中...' : '保存资料'}}
    </button>
  </form>
</view>
